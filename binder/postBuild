#!/usr/bin/env python3
""" perform a development install of jupyterlab_launchpad

    On Binder, this will run _after_ the environment has been fully created from
    the environment.yml in this directory.

    This script should also run locally on Linux/MacOS/Windows:

        python3 binder/postBuild
"""
import json
import os
import subprocess
import sys
from pathlib import Path


ROOT = Path.cwd()
NEBI_DEMO_WORKSPACE = ROOT / "binder" / "nebi-workspaces" / "launchpad-demo"
JUPYTER_CONFIG_PATH = (
    Path(os.environ.get("CONDA_PREFIX", sys.prefix))
    / "etc"
    / "jupyter"
    / "jupyter_server_config.json"
)


def _(*args, **kwargs):
    """ Run a command, echoing the args

        fails hard if something goes wrong
    """
    print("\n\t", " ".join(args), "\n")
    return_code = subprocess.call(args, **kwargs)
    if return_code != 0:
        print("\nERROR", return_code, " ".join(args))
        sys.exit(return_code)


def _nebi_workspace_tracked(path):
    """Return whether nebi already tracks the demo workspace."""
    print("\n\tnebi workspace list --json\n")
    result = subprocess.run(
        ["nebi", "workspace", "list", "--json"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print("\nERROR", result.returncode, "nebi workspace list --json")
        print(result.stderr)
        sys.exit(result.returncode)

    data = json.loads(result.stdout)
    for workspace in data if isinstance(data, list) else []:
        workspace_path = (
            workspace.get("path") if isinstance(workspace, dict) else None
        )
        if (
            isinstance(workspace_path, str)
            and Path(workspace_path).resolve() == path
        ):
            return True
    return False


def _create_nebi_demo_workspace():
    """Create a small tracked Nebi/Pixi workspace for Binder previews."""
    NEBI_DEMO_WORKSPACE.parent.mkdir(exist_ok=True, parents=True)
    if not (NEBI_DEMO_WORKSPACE / "pixi.toml").exists():
        _("pixi", "init", "--format", "pixi", str(NEBI_DEMO_WORKSPACE))

    workspace_path = NEBI_DEMO_WORKSPACE.resolve()
    if not _nebi_workspace_tracked(workspace_path):
        _("nebi", "init", cwd=workspace_path)


def _configure_nebi_kernel_manager():
    """Ensure the Binder preview uses the Nebi kernel provider."""
    JUPYTER_CONFIG_PATH.parent.mkdir(exist_ok=True, parents=True)
    JUPYTER_CONFIG_PATH.write_text(
        json.dumps(
            {
                "ServerApp": {
                    "kernel_spec_manager_class": (
                        "nb_nebi_kernels.NebiKernelSpecManager"
                    )
                },
                "NebiKernelSpecManager": {
                    "workspace_discovery_roots": [
                        str(NEBI_DEMO_WORKSPACE.parent.resolve())
                    ]
                }
            },
            indent=2,
        ),
        encoding="utf-8",
    )


# verify the environment is self-consistent before even starting
_(sys.executable, "-m", "pip", "check")

# install the labextension
_(sys.executable, "-m", "pip", "install", "-e", ".")
_(sys.executable, "-m", "jupyter", "labextension", "develop", "--overwrite", ".")

# create a small nebi workspace so Binder previews show nebi kernel metadata
_create_nebi_demo_workspace()
_configure_nebi_kernel_manager()

# verify the environment the extension didn't break anything
_(sys.executable, "-m", "pip", "check")

# list the extensions
_("jupyter", "server", "extension", "list")

# initially list installed extensions to determine if there are any surprises
_("jupyter", "labextension", "list")


print("JupyterLab with jupyterlab_launchpad is ready to run with:\n")
print("\tjupyter lab\n")
